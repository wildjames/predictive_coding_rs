{
	"name": "PredictiveCodingRust",
	// "image": "mcr.microsoft.com/devcontainers/rust:latest",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"remoteUser": "root",
	"containerEnv": {
		"DISPLAY": "${localEnv:DISPLAY}"
	},
	"mounts": [
		"source=${env:HOME}${env:USERPROFILE}/.ssh,target=/root/.ssh,type=bind"
	],
	"postCreateCommand": "git config --global --add safe.directory /workspaces/PredictiveCodingRust",
	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"vadimcn.vscode-lldb",
				"dustypomerleau.rust-syntax",
				"JScearcy.rust-doc-viewer",
				"ZhangYue.rust-mod-generator",
				"mooman219.rust-assist",
				"jinxdash.prettier-rust",
				"Zerotaskx.rust-extension-pack",
				"mikestead.dotenv"
			]
		}
	}
}
